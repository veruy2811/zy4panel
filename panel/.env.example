APP_NAME=Zy4Store
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://panel.example.com

LOG_CHANNEL=stack
LOG_LEVEL=info

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=zy4hosting
DB_USERNAME=zy4hosting
DB_PASSWORD=

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=database
SESSION_LIFETIME=120

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

ADMIN_NAME=Zy4 Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!

DAEMON_SECRET=
DAEMON_BASE_PATH=/var/lib/zy4daemon
DAEMON_DEFAULT_URL=http://127.0.0.1:7443

PAYMENT_MODE=manual
PAYMENT_BANK_NAME="Manual Payment"
PAYMENT_ACCOUNT_NAME="Zy4Store"
PAYMENT_ACCOUNT_NUMBER="0000000000"
UPLOAD_MAX_SIZE=100M

FILESYSTEM_DISK=local
BCRYPT_ROUNDS=12
